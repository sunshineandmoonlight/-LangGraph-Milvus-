# ============================
# 数据库配置
# ============================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=enterprise_agent
POSTGRES_PORT=5432

# ============================
# Milvus 向量数据库配置
# ============================
MILVUS_HOST=milvus-standalone
MILVUS_PORT=19530

# ============================
# LLM API 配置
# ============================

# SiliconFlow (推荐，国内速度快)
SILICONFLOW_API_KEY=your_siliconflow_api_key_here
SILICONFLOW_API_BASE=https://api.siliconflow.cn/v1
SILICONFLOW_CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct
SILICONFLOW_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
SILICONFLOW_TEMPERATURE=0.7
USE_SILICONFLOW=true

# 智谱 GLM (备选)
GLM_API_KEY=your_glm_api_key_here
GLM_CHAT_MODEL=glm-4-flash
GLM_EMBEDDING_MODEL=embedding-3

# OpenAI (可选，需要代理)
# OPENAI_API_KEY=your_openai_api_key_here

# ============================
# Tavily 网络搜索 API
# ============================
TAVILY_API_KEY=your_tavily_api_key_here

# ============================
# JWT 认证配置
# ============================
# 生产环境请更改此密钥
JWT_SECRET_KEY=your-secret-key-change-this-in-production-min-32-chars

# ============================
# 应用配置
# ============================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ============================
# LangSmith 追踪 (可选)
# ============================
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key
# LANGCHAIN_PROJECT=enterprise-multi-agent

# ============================
# MinIO 配置 (Milvus 依赖)
# ============================
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
